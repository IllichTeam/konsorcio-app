# Local smoke against Supabase (production DB). Copy to `.env.supabase`
# (gitignored) and replace [PASSWORD]. Keep day-to-day `.env` on PGlite —
# do not put these URLs in `.env` or `pnpm dev` may hit production.
#
# Scripts: pnpm db:migrate:prod | db:seed:prod | db:studio:prod | dev:prod
# They load `.env` first (auth/admin/email), then this file (DB overrides).

DB_DRIVER=postgres

# Transaction Pooler (:6543) — app runtime (postgres-js, prepare:false)
DATABASE_URL=postgresql://postgres.irunwiijywgpshzwhuql:8zhJHVcvznJHwdVe@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# Session Pooler (:5432) — Drizzle Kit migrate / push / studio only
# Never use the Transaction Pooler here.
DIRECT_DATABASE_URL=postgresql://postgres.irunwiijywgpshzwhuql:8zhJHVcvznJHwdVe@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
