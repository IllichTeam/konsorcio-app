# Database driver: "pglite" (default, local/testing embedded Postgres via WASM)
# or "postgres" (Supabase Postgres in production / Preview).
DB_DRIVER=pglite

# Runtime Postgres URL (app on Vercel). Required when DB_DRIVER=postgres.
# Prefer Supabase Transaction Pooler (:6543) — postgres-js uses prepare:false
# and max:1 (see src/db/postgres-client-options.ts).
# Example:
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Drizzle Kit only (migrate / push / studio). Direct connection
# (db.PROJECT_REF.supabase.co:5432) or Session Pooler (:5432). Never use the
# Transaction Pooler here. Set in Vercel Production (not required at runtime).
# Example:
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_DATABASE_URL=

# better-auth encryption/signing secret (min 32 chars). Required at runtime.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the app, used by better-auth on the server for absolute URLs /
# cookies. The browser client uses same-origin `/api/auth` (not this value),
# so a mismatched local port no longer breaks sign-in. Keep this aligned with
# the URL you open in the browser when possible.
BETTER_AUTH_URL=http://localhost:3200

# Permanent admin account, consumed by `pnpm db:seed` (src/db/seed-admin.ts).
# If the admin doesn't exist yet it's created with role "admin"; if it already
# exists, its role and password are reset to these values (env wins). Public
# sign-up is disabled (`disableSignUp: true`), so this is the only way to
# provision the first account. Password must be at least 8 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend API key used to send transactional email. Required at send time for
# notifications (see src/lib/email/client.ts). When unset, OTP/forgot-password
# emails are logged to stdout so local/pglite dev works without Resend.
# Get one at https://resend.com/api-keys.
RESEND_API_KEY=

# Default "from" address for outgoing email. Must be a verified domain/sender
# in Resend to work outside of onboarding@resend.dev testing.
EMAIL_FROM=Konsorcio <onboarding@resend.dev>

# Temporary: redirect every outbound Resend recipient (notifications + OTP) to
# this address while the production domain is unverified. Unset when the domain
# is verified so real recipients receive mail again.
EMAIL_OVERRIDE_TO=illich570@gmail.com
